---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Test Álvarez: protocolo progresivo de 400 m. App para Garmin y analizador de resultados.' } = Astro.props;
const base = import.meta.env.BASE_URL;
const nav = [
  { href: base, label: 'Inicio' },
  { href: `${base}metodo`, label: 'Método' },
  { href: `${base}test`, label: 'El test' },
  { href: `${base}analisis`, label: 'Análisis' },
];
const current = Astro.url.pathname.replace(/\/$/, '');
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script defer src="https://analytics.perezpereira.com/script.js" data-website-id="f22283c7-d39e-4c7c-9ec6-1df44867f34b"></script>
  </head>
  <body class="bg-paper text-ink">
    <header class="sticky top-0 z-20 border-b border-ink/10 bg-paper/90 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-baseline justify-between px-6 py-4">
        <a href={base} class="font-display text-xl tracking-tight">Test Álvarez</a>
        <ul class="flex gap-6 text-sm">
          {nav.slice(1).map((item) => {
            const href = item.href.replace(/\/$/, '');
            const active = current === href;
            return (
              <li>
                <a
                  href={item.href}
                  class={`hover:text-accent ${active ? 'text-ink' : 'text-ink/60'}`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-6 pt-10 md:pt-14 pb-16 md:pb-24">
      <slot />
    </main>

    <footer class="border-t border-ink/10 py-12 text-sm text-ink/60">
      <div class="mx-auto max-w-5xl px-6">
        <p>
          <a href="https://github.com/marioperezpereira/alvarez" class="underline-offset-4 hover:underline">GitHub</a>
          · <a href={`${base}metodo#referencias`} class="underline-offset-4 hover:underline">Referencias</a>
          · <a href="https://product.perezpereira.com/" class="underline-offset-4 hover:underline">Un producto Pérez Pereira</a>
        </p>
      </div>
    </footer>
  </body>
</html>
