---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const devices = [
  'Fenix 5 / 5S / 5X / 5 Plus',
  'Fenix 6 / 6S / 6 Pro / 6X Pro',
  'Fenix 7 / 7S / 7X / 7 Pro / 7S Pro / 7X Pro',
  'Fenix 8 / 8 Pro / 8 Solar / Fenix E',
  'Forerunner 245 / 255 / 265 / 745 / 935 / 945 / 955 / 965 / 970',
  'Enduro / Enduro 3',
  'Epix 2 / Epix 2 Pro (42/47/51 mm)',
  'Venu 2 / 2S / 2 Plus / 3 / 3S',
];
---
<Base title="App Garmin · DIPER-Álvarez">
  <p class="mb-4 text-sm uppercase tracking-widest text-ink/50">Durante el test</p>
  <h1 class="font-display text-5xl leading-tight tracking-tight md:text-6xl">
    Una sola pantalla.<br />El tiempo correcto, cada 400 m.
  </h1>
  <p class="mt-6 max-w-xl text-lg text-ink/80">
    <em>Alvarez — Diper</em> es una app de reloj para Garmin que ejecuta el protocolo completo:
    calcula el objetivo de cada vuelta, emite un tono cada cuarto de 400 m como metrónomo,
    y graba la actividad en FIT estándar para que luego la subas a Connect.
  </p>

  <section class="mt-16 grid gap-10 md:grid-cols-3">
    <figure>
      <img src={`${base}images/screen_menu.png`} alt="Menú principal" class="w-full rounded border border-ink/10" />
      <figcaption class="mt-3 text-sm text-ink/60">Fija tu primera vuelta y modo antes de empezar.</figcaption>
    </figure>
    <figure>
      <img src={`${base}images/screen_activity.png`} alt="Pantalla de actividad" class="w-full rounded border border-ink/10" />
      <figcaption class="mt-3 text-sm text-ink/60">Tiempo grande, objetivo visible, barra de progreso con marcas de cuarto.</figcaption>
    </figure>
    <figure>
      <img src={`${base}images/screen_summary.png`} alt="Resumen" class="w-full rounded border border-ink/10" />
      <figcaption class="mt-3 text-sm text-ink/60">Resumen por vuelta: tiempo, ritmo máximo y pulso.</figcaption>
    </figure>
  </section>

  <section class="mt-20 grid gap-12 md:grid-cols-2">
    <div>
      <h2 class="font-display text-3xl">Lo que hace</h2>
      <ul class="mt-5 space-y-2 text-ink/80">
        <li>· Elige tu 1ª vuelta (de 2:00 a 4:00 en pasos de 4 s).</li>
        <li>· Muestra el objetivo de cada vuelta y resalta si te pasas.</li>
        <li>· Tono + vibración en cada cuarto de vuelta (100 m).</li>
        <li>· Tono triple al cerrar vuelta.</li>
        <li>· Modo manual (botón de vuelta) o automático por GPS (400 m).</li>
        <li>· Graba actividad FIT estándar para Garmin Connect, Strava, etc.</li>
      </ul>
    </div>
    <div>
      <h2 class="font-display text-3xl">Dispositivos compatibles</h2>
      <ul class="mt-5 space-y-2 text-ink/80">
        {devices.map((d) => <li>· {d}</li>)}
      </ul>
      <p class="mt-6 text-xs text-ink/50">Total: 92 dispositivos. Ver lista completa en la ficha de Connect IQ.</p>
    </div>
  </section>

  <section class="mt-20 rounded border border-ink/10 bg-white/40 p-8">
    <h2 class="font-display text-3xl">Instalar</h2>
    <p class="mt-3 text-ink/80">
      La app se distribuye vía Connect IQ Store. Actualmente en <strong>beta</strong>.
      Instálala desde el móvil en la app Connect IQ o accede al enlace del store:
    </p>
    <a
      href="https://apps.garmin.com/en-US/apps/2cf041b6-28ad-4d4d-ba77-31f2a947d2b1"
      class="mt-5 inline-block rounded-full bg-ink px-5 py-2 text-sm text-paper hover:opacity-90"
    >
      Ver en Connect IQ Store →
    </a>
  </section>
</Base>
